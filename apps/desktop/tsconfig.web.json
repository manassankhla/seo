{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "outDir": "./out-types/web",
    "rootDir": "./src/renderer",
    "baseUrl": "./src/renderer",
    "paths": {
      "@renderer/*": ["src/*"]
    }
  },
  "include": ["src/renderer/**/*"],
  "references": [{ "path": "../../packages/shared-types" }]
}
