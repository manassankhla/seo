{
  "name": "@freecrawl/cli",
  "version": "0.2.7",
  "private": true,
  "type": "module",
  "bin": {
    "freecrawl": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node ./dist/index.js",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@freecrawl/core": "*",
    "@freecrawl/db": "*",
    "@freecrawl/shared-types": "*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.0"
  }
}
