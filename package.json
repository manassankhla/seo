{
  "name": "freecrawl-seo",
  "version": "0.2.7",
  "private": true,
  "description": "Open-source desktop SEO crawler â€” a free alternative to Screaming Frog",
  "license": "MIT",
  "author": "kemalai",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/desktop",
    "build": "tsc -b && npm run build --workspace apps/desktop && npm run build --workspace apps/cli",
    "build:desktop": "npm run build --workspace apps/desktop",
    "build:cli": "npm run build --workspace apps/cli",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,css,html}\"",
    "test": "npm run test --workspaces --if-present",
    "cli": "npm run start --workspace apps/cli --",
    "build:web": "tsc -b && npm run build:next",
    "start:web": "npm run start:next",
    "build:next": "npm run build --workspace apps/web",
    "start:next": "npm run start --workspace apps/web"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0"
  }
}
